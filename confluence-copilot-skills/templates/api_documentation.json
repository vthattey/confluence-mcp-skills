{
  "name": "api_documentation",
  "description": "Template for REST API technical documentation pages — mirrors the Java REST API Generator output.",
  "created_at": "2026-04-24T00:00:00+00:00",
  "source_page_id": null,
  "variables": [
    { "name": "api_name",       "description": "API name (e.g. Employee API)",             "required": true,  "default": "" },
    { "name": "api_version",    "description": "API version (e.g. 1.0)",                    "required": true,  "default": "1.0" },
    { "name": "base_url",       "description": "Base URL path (e.g. /api/v1/employees)",    "required": true,  "default": "" },
    { "name": "owner_team",     "description": "Owning team name",                          "required": true,  "default": "" },
    { "name": "overview",       "description": "One-paragraph API description",             "required": true,  "default": "" },
    { "name": "auth_server",    "description": "OAuth2 auth server URL",                    "required": false, "default": "https://auth.your-org.com" },
    { "name": "last_updated",   "description": "Date last updated (YYYY-MM-DD)",            "required": false, "default": "" },
    { "name": "endpoints_table","description": "Confluence storage-format table of endpoints", "required": true, "default": "" },
    { "name": "models_section", "description": "Confluence storage-format request/response model tables", "required": true, "default": "" },
    { "name": "error_table",    "description": "Confluence storage-format error reference table", "required": false, "default": "" }
  ],
  "body": "<h1>{{ api_name }} — Technical Reference</h1>\n<p><strong>Version:</strong> {{ api_version }}<br/>\n<strong>Base URL:</strong> <code>{{ base_url }}</code><br/>\n<strong>Owner:</strong> {{ owner_team }}<br/>\n<strong>Last Updated:</strong> {{ last_updated }}</p>\n<hr/>\n\n<h2>Overview</h2>\n<p>{{ overview }}</p>\n\n<h2>Authentication</h2>\n<p>All endpoints require a Bearer token obtained from <a href=\"{{ auth_server }}\">{{ auth_server }}</a>.</p>\n<table>\n  <tbody>\n    <tr><th>Header</th><th>Value</th></tr>\n    <tr><td><code>Authorization</code></td><td><code>Bearer &lt;token&gt;</code></td></tr>\n    <tr><td><code>X-traceId</code></td><td>Distributed trace ID (required)</td></tr>\n    <tr><td><code>X-spanId</code></td><td>Span ID (required)</td></tr>\n    <tr><td><code>countryCode</code></td><td>ISO 3166-1 alpha-2 (required)</td></tr>\n    <tr><td><code>OriginatingApplCode</code></td><td>Calling application code (required)</td></tr>\n  </tbody>\n</table>\n\n<h2>Endpoints</h2>\n{{ endpoints_table }}\n\n<h2>Request and Response Models</h2>\n{{ models_section }}\n\n<h2>Error Reference</h2>\n{{ error_table }}\n\n<h2>Technology Stack</h2>\n<table>\n  <tbody>\n    <tr><th>Layer</th><th>Technology</th></tr>\n    <tr><td>Language</td><td>Java 17</td></tr>\n    <tr><td>Framework</td><td>Spring Boot 3.2</td></tr>\n    <tr><td>Persistence</td><td>Spring Data JPA</td></tr>\n    <tr><td>Testing</td><td>JUnit 5, Mockito, AssertJ</td></tr>\n  </tbody>\n</table>\n\n<h2>Changelog</h2>\n<table>\n  <tbody>\n    <tr><th>Version</th><th>Date</th><th>Author</th><th>Changes</th></tr>\n    <tr><td>{{ api_version }}</td><td>{{ last_updated }}</td><td>{{ owner_team }}</td><td>Initial release</td></tr>\n  </tbody>\n</table>"
}
